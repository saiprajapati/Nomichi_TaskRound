# Copy this file to .env.local and fill in your own values.
# Never commit .env.local — it is already in .gitignore.

# Supabase project settings (Project Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic API key, used server-side only for the AI assist features
# on the lead detail page (WhatsApp draft, call log summary, vibe-check).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
